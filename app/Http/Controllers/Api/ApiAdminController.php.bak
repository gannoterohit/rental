    // ─────────────────────────────────────────
    //  PLANS MANAGEMENT
    // ─────────────────────────────────────────

    /**
     * List all plans
     */
    public function plans(Request $request)
    {
        $plans = Plan::latest()->get();
        return $this->sendSuccess($plans);
    }

    /**
     * Create a plan
     */
    public function createPlan(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'name'           => 'required|string|max:255',
            'price'          => 'required|numeric|min:0',
            'duration_days'  => 'required|integer|min:1',
            'listing_limit'  => 'required|integer|min:-1',
            'contacts_limit' => 'nullable|integer|min:-1',
            'type'           => 'required|in:owner,user',
            'benefits'       => 'nullable|array',
            'is_active'      => 'nullable|boolean',
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }

        $plan = Plan::create($request->only([
            'name', 'price', 'duration_days', 'listing_limit',
            'contacts_limit', 'type', 'benefits', 'is_active'
        ]));
        return $this->sendSuccess($plan, 'Plan created successfully', 201);
    }

    /**
     * Update a plan
     */
    public function updatePlan(Request $request, $id)
    {
        $plan = Plan::find($id);
        if (!$plan) {
            return $this->sendError('Plan not found', [], 404);
        }

        $plan->update($request->only([
            'name', 'price', 'duration_days', 'listing_limit',
            'contacts_limit', 'type', 'benefits', 'is_active'
        ]));
        return $this->sendSuccess($plan, 'Plan updated successfully');
    }

    /**
     * Toggle plan active status
     */
    public function togglePlan($id)
    {
        $plan = Plan::find($id);
        if (!$plan) {
            return $this->sendError('Plan not found', [], 404);
        }

        $plan->update(['is_active' => !$plan->is_active]);
        return $this->sendSuccess(['is_active' => $plan->is_active], 'Plan status updated');
    }

    /**
     * Delete a plan
     */
    public function deletePlan($id)
    {
        $plan = Plan::find($id);
        if (!$plan) {
            return $this->sendError('Plan not found', [], 404);
        }
        $plan->delete();
        return $this->sendSuccess([], 'Plan deleted successfully');
    }

    // ─────────────────────────────────────────
    //  SETTINGS
    // ─────────────────────────────────────────

    /**
     * Get all settings
     */
    public function settings()
    {
        $settings = Setting::all()->pluck('value', 'key');
        return $this->sendSuccess($settings);
    }

    /**
     * Update settings
     */
    public function updateSettings(Request $request)
    {
        $data = $request->all();

        foreach ($data as $key => $value) {
            Setting::set($key, $value);
        }

        return $this->sendSuccess([], 'Settings updated successfully');
    }

    // ─────────────────────────────────────────
    //  ANALYTICS
    // ─────────────────────────────────────────

    /**
     * Search analytics summary
     */
    public function analytics()
    {
        // Top searched cities
        $topCities = Room::where('status', 'active')
            ->selectRaw('city, COUNT(*) as count')
            ->groupBy('city')
            ->orderByDesc('count')
            ->limit(10)
            ->get();

        // Bookings per month
        $bookingsPerMonth = Booking::selectRaw('MONTH(created_at) as month, COUNT(*) as count')
            ->whereYear('created_at', now()->year)
            ->groupBy('month')
            ->pluck('count', 'month');

        $bookingData = [];
        for ($i = 1; $i <= 12; $i++) {
            $bookingData[] = (int) ($bookingsPerMonth[$i] ?? 0);
        }

        // New users per month
        $usersPerMonth = User::selectRaw('MONTH(created_at) as month, COUNT(*) as count')
            ->whereYear('created_at', now()->year)
            ->where('role', 'user')
            ->groupBy('month')
            ->pluck('count', 'month');

        $userData = [];
        for ($i = 1; $i <= 12; $i++) {
            $userData[] = (int) ($usersPerMonth[$i] ?? 0);
        }

        return $this->sendSuccess([
            'top_cities'       => $topCities,
            'bookings_monthly' => $bookingData,
            'users_monthly'    => $userData,
        ]);
    }

    // ─────────────────────────────────────────
    //  BLOGS MANAGEMENT
    // ─────────────────────────────────────────

    /**
     * List all blogs (including unpublished)
     */
    public function blogs(Request $request)
    {
        $query = \App\Models\Blog::latest();

        if ($request->filled('published')) {
            $query->where('is_published', $request->published === 'true');
        }

        $blogs = $query->paginate($request->get('limit', 15));
        return \App\Http\Resources\BlogResource::collection($blogs)->additional(['status' => 'success']);
    }

    /**
     * Create a blog post
     */
    public function createBlog(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'title'        => 'required|string|max:255',
            'slug'         => 'required|string|unique:blogs,slug',
            'content'      => 'required|string',
            'is_published' => 'nullable|boolean',
            'image'        => 'nullable|image|max:2048',
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }

        $data = $request->only(['title', 'slug', 'content', 'excerpt', 'meta_title', 'meta_description', 'is_published']);

        if ($request->hasFile('image')) {
            $data['image'] = $request->file('image')->store('blogs', 'public');
        }

        $blog = \App\Models\Blog::create($data);
        return $this->sendSuccess(new \App\Http\Resources\BlogResource($blog), 'Blog created successfully', 201);
    }

    /**
     * Update a blog post
     */
    public function updateBlog(Request $request, $id)
    {
        $blog = \App\Models\Blog::find($id);
        if (!$blog) {
            return $this->sendError('Blog not found', [], 404);
        }

        $validator = Validator::make($request->all(), [
            'title'        => 'required|string|max:255',
            'slug'         => 'required|string|unique:blogs,slug,' . $id,
            'content'      => 'required|string',
            'is_published' => 'nullable|boolean',
            'image'        => 'nullable|image|max:2048',
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }

        $data = $request->only(['title', 'slug', 'content', 'excerpt', 'meta_title', 'meta_description', 'is_published']);

        if ($request->hasFile('image')) {
            $data['image'] = $request->file('image')->store('blogs', 'public');
        }

        $blog->update($data);
        return $this->sendSuccess(new \App\Http\Resources\BlogResource($blog), 'Blog updated successfully');
    }

    /**
     * Delete a blog post
     */
    public function deleteBlog($id)
    {
        $blog = \App\Models\Blog::find($id);
        if (!$blog) {
            return $this->sendError('Blog not found', [], 404);
        }
        $blog->delete();
        return $this->sendSuccess([], 'Blog deleted successfully');
    }

    // ─────────────────────────────────────────
    //  OFFERS MANAGEMENT
    // ─────────────────────────────────────────

    /**
     * List all offers
     */
    public function offers(Request $request)
    {
        $query = Offer::latest();
        if ($request->filled('is_active')) {
            $query->where('is_active', $request->is_active === 'true');
        }
        return $this->sendSuccess($query->get());
    }

    /**
     * Create an offer
     */
    public function createOffer(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'title'           => 'required|string|max:255',
            'description'     => 'required|string',
            'discount_text'   => 'nullable|string|max:50',
            'target_audience' => 'required|in:user,owner,both',
            'banner_color'    => 'required|string|max:7',
            'placement'       => 'required|in:top_nav,home_hero,dashboard,sidebar,popup',
            'type'            => 'required|in:text_only,image_only,both',
            'link_url'        => 'nullable|url|max:255',
            'image'           => 'nullable|image|max:2048',
            'start_date'      => 'nullable|date',
            'end_date'        => 'nullable|date|after_or_equal:start_date',
            'is_active'       => 'nullable|boolean',
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }

        $data = $request->only([
            'title','description','discount_text','target_audience',
            'banner_color','placement','type','link_url','start_date','end_date','is_active'
        ]);

        if ($request->hasFile('image')) {
            $data['image_path'] = $request->file('image')->store('offers', 'public');
        }

        $offer = Offer::create($data);
        return $this->sendSuccess($offer, 'Offer created successfully', 201);
    }

    /**
     * Update an offer
     */
    public function updateOffer(Request $request, $id)
    {
        $offer = Offer::find($id);
        if (!$offer) {
            return $this->sendError('Offer not found', [], 404);
        }

        $data = $request->only([
            'title','description','discount_text','target_audience',
            'banner_color','placement','type','link_url','start_date','end_date','is_active'
        ]);

        if ($request->hasFile('image')) {
            if ($offer->image_path) {
                Storage::disk('public')->delete($offer->image_path);
            }
            $data['image_path'] = $request->file('image')->store('offers', 'public');
        }

        $offer->update($data);
        return $this->sendSuccess($offer, 'Offer updated successfully');
    }

    /**
     * Toggle offer active status
     */
    public function toggleOffer($id)
    {
        $offer = Offer::find($id);
        if (!$offer) {
            return $this->sendError('Offer not found', [], 404);
        }
        $offer->update(['is_active' => !$offer->is_active]);
        return $this->sendSuccess(['is_active' => $offer->is_active], 'Offer status updated');
    }

    /**
     * Delete an offer
     */
    public function deleteOffer($id)
    {
        $offer = Offer::find($id);
        if (!$offer) {
            return $this->sendError('Offer not found', [], 404);
        }
        if ($offer->image_path) {
            Storage::disk('public')->delete($offer->image_path);
        }
        $offer->delete();
        return $this->sendSuccess([], 'Offer deleted successfully');
    }

    // ─────────────────────────────────────────
    //  REJECTION REASONS MANAGEMENT
    // ─────────────────────────────────────────

    /**
     * Store a new rejection reason
     */
    public function storeRejectionReason(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'reason' => 'required|string|max:255'
        ]);
        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }
        $reason = RejectionReason::create([
            'reason'    => $request->reason,
            'is_active' => true
        ]);
        return $this->sendSuccess($reason, 'Rejection reason added', 201);
    }

    /**
     * Update a rejection reason
     */
    public function updateRejectionReason(Request $request, $id)
    {
        $reason = RejectionReason::find($id);
        if (!$reason) {
            return $this->sendError('Reason not found', [], 404);
        }
        $validator = Validator::make($request->all(), [
            'reason' => 'required|string|max:255'
        ]);
        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }
        $reason->update(['reason' => $request->reason]);
        return $this->sendSuccess($reason, 'Rejection reason updated');
    }

    /**
     * Delete (deactivate) a rejection reason
     */
    public function deleteRejectionReason($id)
    {
        $reason = RejectionReason::find($id);
        if (!$reason) {
            return $this->sendError('Reason not found', [], 404);
        }
        $reason->update(['is_active' => false]);
        return $this->sendSuccess([], 'Rejection reason deleted');
    }

    // ─────────────────────────────────────────
    //  STATIC PAGES MANAGEMENT
    // ─────────────────────────────────────────

    /**
     * Update a static page content (terms, privacy, condition, contact, faq)
     * slug: terms-and-conditions | privacy-policy | condition-policy | contact-us | faq
     */
    public function updatePage(Request $request, $slug)
    {
        $keyMap = [
            'terms-and-conditions' => 'terms_content',
            'privacy-policy'       => 'privacy_content',
            'condition-policy'     => 'condition_content',
            'contact-us'           => 'contact_content',
            'faq'                  => 'faq_content',
        ];

        if (!isset($keyMap[$slug])) {
            return $this->sendError('Invalid page slug', [], 404);
        }

        $validator = Validator::make($request->all(), [
            'content' => 'required|string',
        ]);
        if ($validator->fails()) {
            return $this->sendError('Validation failed', $validator->errors(), 422);
        }

        $key     = $keyMap[$slug];
        $setting = Setting::where('key', $key)->first();

        if ($setting) {
            $setting->update(['value' => $request->content]);
        } else {
            Setting::create([
                'key'   => $key,
                'value' => $request->content,
                'type'  => 'textarea',
                'group' => 'pages'
            ]);
        }

        return $this->sendSuccess([], ucwords(str_replace('-', ' ', $slug)) . ' updated successfully');
    }

    // ─────────────────────────────────────────
    //  SEARCH ANALYTICS (detailed)
    // ─────────────────────────────────────────

    /**
     * Detailed search analytics — top searched cities, listing cities, recent logs
     */
    public function searchAnalytics(Request $request)
    {
        $topSearchedCities = SearchLog::whereNotNull('city')
            ->where('city', '!=', '')
            ->select('city', DB::raw('count(*) as total'))
            ->groupBy('city')
            ->orderByDesc('total')
            ->limit(10)
            ->get();

        $topListingCities = Room::whereNotNull('city')
            ->where('city', '!=', '')
            ->select('city', DB::raw('count(*) as total'))
            ->groupBy('city')
            ->orderByDesc('total')
            ->limit(10)
            ->get();

        $recentLogs = SearchLog::with('user')
            ->orderByDesc('created_at')
            ->paginate($request->get('limit', 20));

        return $this->sendSuccess([
            'top_searched_cities' => $topSearchedCities,
            'top_listing_cities'  => $topListingCities,
            'recent_logs'         => $recentLogs,
        ]);
    }
}
